// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  username     String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  entries      MediaEntry[]

  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")

  friendshipsA Friendship[] @relation("FriendA")
  friendshipsB Friendship[] @relation("FriendB")

  groupsCreated    Group[]
  groupMemberships GroupMember[]
  groupEntries     GroupMediaEntry[]
}

enum MediaType {
  BOOK
  LIGHT_NOVEL
  MANGA
  MANWHA
  MANHUA
  COMIC
  MOVIE
  SERIES
  ANIME
  VIDEO_GAME
  OTHER
}

enum MediaStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

model Media {
  id                String            @id @default(uuid())
  title             String
  type              MediaType
  createdAt         DateTime          @default(now())
  entries           MediaEntry[]
  groupMediaEntries GroupMediaEntry[]
}

model MediaEntry {
  id          String      @id @default(uuid())
  userId      String
  mediaId     String
  status      MediaStatus @default(PLANNED)
  rating      Int?
  progress    Int?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
}

model FriendRequest {
  id          String   @id @default(uuid())
  requesterId String
  receiverId  String
  createdAt   DateTime @default(now())

  requester User @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model Friendship {
  id        String   @id @default(uuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  userA User @relation("FriendA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
}

model Group {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  createdById String

  createdBy User @relation(fields: [createdById], references: [id])

  members GroupMember[]
  entries GroupMediaEntry[]

  @@unique([createdById, name])
  @@index([createdById])
}

enum GroupRole {
  OWNER
  MEMBER
}

model GroupMember {
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
}

model GroupMediaEntry {
  id          String      @id @default(uuid())
  groupId     String
  mediaId     String
  status      MediaStatus @default(PLANNED)
  rating      Int?
  progress    Int?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  addedById   String

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  addedBy User  @relation(fields: [addedById], references: [id])

  @@unique([groupId, mediaId])
  @@index([groupId, mediaId])
}
